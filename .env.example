# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_db

# Airflow
# 호스트 사용자 UID 와 맞추기 (Linux/Mac):  echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# 세션 유지를 위해 반드시 랜덤 문자열로 교체.
# 생성:  python3 -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-to-a-random-32-byte-hex-string
