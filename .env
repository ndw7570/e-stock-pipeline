# ============================================
# 공통 변수 (모든 환경)
# 환경별로 다른 값은 .env.dev / .env.prod 에서 override
# ============================================

# -- Postgres --
POSTGRES_USER=estock

# -- Airflow --
AIRFLOW_UID=50000

# -- Kafka 클러스터 메타 --
KAFKA_ADVERTISED_HOST=localhost

# -- 모든 서비스를 외부에 노출하지 않음 (보안 기본값) --
ZOOKEEPER_BIND_HOST=127.0.0.1
KAFKA_BIND_HOST=127.0.0.1
KAFKA_UI_BIND_HOST=0.0.0.0
POSTGRES_BIND_HOST=127.0.0.1
AIRFLOW_WEBSERVER_BIND_HOST=0.0.0.0