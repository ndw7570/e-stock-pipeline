cat > .env.example << 'EOF'
# ============================================
# 이 파일을 .env / .env.dev / .env.prod 로 복사 후 실제 값으로 채우세요.
#
# 사용 패턴:
#   1. .env 에 공통 변수 작성
#   2. .env.dev 또는 .env.prod 에 환경별 차이만 작성
#   3. 실행:  make dev-up  (또는 make prod-up)
# ============================================

# ---- 공통 (.env 에 넣을 것) ----
POSTGRES_USER=estock
AIRFLOW_UID=50000
KAFKA_ADVERTISED_HOST=localhost
ZOOKEEPER_BIND_HOST=127.0.0.1
KAFKA_BIND_HOST=127.0.0.1
KAFKA_UI_BIND_HOST=127.0.0.1
POSTGRES_BIND_HOST=127.0.0.1
AIRFLOW_WEBSERVER_BIND_HOST=127.0.0.1

# ---- 환경별 (.env.dev / .env.prod 에 넣을 것) ----
COMPOSE_PROJECT_NAME=estock-dev
CONTAINER_PREFIX=estock-dev
POSTGRES_PASSWORD=change-me
POSTGRES_DB=estock_dev

# 생성: python3 -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=change-me
# 생성: docker run --rm apache/airflow:2.10.0-python3.11 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change-me

ZOOKEEPER_HOST_PORT=12181
KAFKA_HOST_PORT=19092
KAFKA_UI_HOST_PORT=18088
POSTGRES_HOST_PORT=15439
AIRFLOW_WEBSERVER_HOST_PORT=18080

# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=change-me
KIS_APP_SECRET=change-me
# dev: https://openapivts.koreainvestment.com:29443  (모의투자)
# prod: https://openapi.koreainvestment.com:9443     (실전)
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
EOF